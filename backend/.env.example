# LLM 配置 - 统一使用 LLM_API_KEY 命名，兼容多种模型
LLM_API_KEY=#在环境变量中设置 export "LLM_API_KEY"
# model 可以是标准模型 ID（如 doubao-seed-2-0-lite-260215）或自定义接入点 ID（如 ep-xxx）
LLM_MODEL=doubao-seed-2-0-lite-260215
# base_url 只到 /api/v3，不要带 /chat/completions（OpenAI SDK 会自动追加）
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Embedding 配置
# 向量化模型由后端固定使用；Android 端只显示连接状态，不提供切换入口。
USE_EXTERNAL_EMBEDDING=false
# 兼容旧开关；设置为 true 也会启用外部向量化服务。
USE_DOUBAO_EMBEDDING=false
EMBEDDING_MODEL=doubao-embedding-vision-251215
EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
EMBEDDING_DIMENSIONS=2048
# 可直接设置 EMBEDDING_API_KEY，也可通过 EMBEDDING_API_KEY_ENV 指向已有环境变量。
EMBEDDING_API_KEY=
EMBEDDING_API_KEY_ENV=ARK_API_KEY

# Chroma 配置
CHROMA_PATH=./data/chroma
CHROMA_COLLECTION_NAME=agent_knowledge

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# CORS 配置（生产环境应限制为特定域名）
CORS_ORIGINS=["*"]
